---
/**
 * Blog Index - Lists all blog posts
 * URL: /blog
 */
import BaseLayout from '@sfw/ui';
import { HeroSection, BlogGrid, CTASection } from '@sfw/ui';
import { serviceConfigs } from '@sfw/content';
import { blogPosts } from '../../data/blog-posts';

const config = serviceConfigs['dry-rot'];
const sortedPosts = [...blogPosts].sort(
  (a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime()
);
---

<BaseLayout
  title={`Blog | ${config.primaryService} Tips & Insights`}
  description={`Expert ${config.primaryService.toLowerCase()} guidance, repair checklists, and homeowner maintenance advice.`}
  config={config}
  logo="/logo.png"
  navigation={[
    { label: 'Home', url: '/' },
    { label: 'Services', url: '/services' },
    { label: 'Blog', url: '/blog' },
    { label: 'Locations', url: '/locations' },
  ]}
>
  <HeroSection
    headline={`${config.primaryService} Blog`}
    subheadline="Actionable guides, prevention tips, and practical repair insights for homeowners."
    height="sm"
  />

  <BlogGrid
    posts={sortedPosts}
    title="Latest Articles"
    subtitle="Use these resources to plan repairs, avoid common issues, and make better maintenance decisions."
    class="bg-white"
  />

  <CTASection
    headline="Need Professional Help?"
    description={`Talk with our team about your ${config.primaryService.toLowerCase()} project and next steps.`}
    primaryCTA={{ text: `Call ${config.phone}`, href: `tel:${config.phone}` }}
    secondaryCTA={{ text: 'Explore Services', href: '/services' }}
    variant="dark"
  />
</BaseLayout>
