---
/**
 * BlogCard.astro - Blog post preview card
 * Displays blog post with image, title, excerpt, and metadata
 */
import type { BaseProps, BlogPost } from '@sfw/ui/types';
import Image from '../ui/Image.astro';
import Button from '../ui/Button.astro';

export interface Props extends BaseProps {
  post: BlogPost;
  showExcerpt?: boolean;
}

const {
  post,
  showExcerpt = true,
  class: className = '',
  ...rest
} = Astro.props;

const { title, excerpt, image, slug, publishDate, author, category } = post;
const postUrl = `/blog/${slug}`;
const strippedContent = post.content?.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim() || '';
const wordCount = strippedContent ? strippedContent.split(' ').length : 0;
const readingTime = wordCount ? Math.max(1, Math.round(wordCount / 225)) : null;
const displayExcerpt = excerpt?.trim() && excerpt.trim() !== '`markdown'
  ? excerpt.trim()
  : strippedContent.slice(0, 165) + (strippedContent.length > 165 ? '...' : '');

const classes = [
  'bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-200 h-full flex flex-col',
  className,
].filter(Boolean).join(' ');

// Format date
const formattedDate = publishDate ? new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : '';
---

<article class={classes} {...rest}>
  <!-- Featured Image -->
  {image && (
    <a href={postUrl} class="block overflow-hidden">
      <Image
        src={image}
        alt={title}
        class="w-full h-52 object-cover transition-transform duration-300 hover:scale-105"
      />
    </a>
  )}

  <!-- Content -->
  <div class="p-6 flex-1 flex flex-col">
    <!-- Category & Date -->
    <div class="flex items-center justify-between gap-3 text-xs sm:text-sm text-gray-500 mb-3">
      {category && (
        <span class="bg-primary/10 text-primary px-3 py-1 rounded-full font-semibold">
          {category}
        </span>
      )}
      <div class="text-right">
        {formattedDate && (
          <time datetime={publishDate} class="block">{formattedDate}</time>
        )}
        {readingTime && <span class="block">{readingTime} min read</span>}
      </div>
    </div>

    <!-- Title -->
    <h3 class="text-xl font-heading font-bold text-dark mb-3 line-clamp-2 hover:text-primary transition-colors">
      <a href={postUrl} aria-label={`Read article: ${title}`}>{title}</a>
    </h3>

    <!-- Excerpt -->
    {showExcerpt && displayExcerpt && (
      <p class="text-gray-600 mb-4 flex-1 line-clamp-3">
        {displayExcerpt}
      </p>
    )}

    <!-- Author -->
    {author && (
      <div class="text-sm text-gray-500 mb-4">
        By {author}
      </div>
    )}

    <!-- Read More -->
    <div>
      <Button href={postUrl} variant="outline" size="sm">
        Read article
      </Button>
    </div>
  </div>
</article>
