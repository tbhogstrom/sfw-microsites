---
/**
 * CCBBanner.astro - CCB License banner above footer
 * Displays license information above footer
 */
import type { BaseProps } from '@sfw/ui/types';

export interface Props extends BaseProps {
  ccbNumber?: string;
  waLicenseNumber?: string;
}

const {
  ccbNumber = '259926',
  waLicenseNumber = 'SFWCOC*745BH',
  class: className = '',
  ...rest
} = Astro.props;
---

<div class={`bg-gray-100 border-t border-gray-200 py-4 ${className}`} {...rest}>
  <div class="container mx-auto px-4">
    <p class="text-center text-xs text-gray-600">
      <span class="font-medium whitespace-nowrap">OR CCB# {ccbNumber}</span>
      {' '}<span class="text-gray-400">|</span>{' '}
      <span class="font-medium whitespace-nowrap">WA LIC# {waLicenseNumber}</span>
    </p>
  </div>
</div>
