  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@vercel/analytics": "^1.6.1"
  }
}
